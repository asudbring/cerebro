{
  "interactionModel": {
    "languageModel": {
      "invocationName": "cerebro",
      "intents": [
        {
          "name": "CaptureThoughtIntent",
          "slots": [
            {
              "name": "thought",
              "type": "AMAZON.SearchQuery"
            }
          ],
          "samples": [
            "capture {thought}",
            "remember {thought}",
            "save {thought}",
            "note {thought}",
            "store {thought}",
            "record {thought}",
            "log {thought}",
            "{thought}"
          ]
        },
